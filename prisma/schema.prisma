generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  name             String?
  email            String?            @unique(map: "User_email_key")
  password         String
  totalXp          Int                @default(0)
  level            Int                @default(1)
  streak           Int                @default(0)
  lastActive       DateTime?
  createdAt        DateTime           @default(now())
  grade            String             @default("SD")
  titles           String?            @db.Text
  image            String?            @db.LongText
  health           Int                @default(5)
  lastHealthReset  DateTime?
  gamePoints       Int                @default(0)
  analytics        Analytics[]
  gameProgress     GameProgress[]
  learningProgress LearningProgress[]
  progress         UserProgress[]

  @@map("users")
}

model MathTopic {
  id           String         @id @default(cuid())
  title        String
  description  String
  category     String
  difficulty   Int
  questions    Question[]
  userProgress UserProgress[]

  @@map("mathtopic")
}

model Question {
  id            String    @id @default(cuid())
  topicId       String
  questionText  String
  correctAnswer String
  options       String    @db.LongText
  xpReward      Int       @default(10)
  topic         MathTopic @relation(fields: [topicId], references: [id], map: "Question_topicId_fkey")

  @@index([topicId], map: "Question_topicId_fkey")
  @@map("question")
}

model UserProgress {
  id          String    @id @default(cuid())
  userId      String
  topicId     String
  isUnlocked  Boolean   @default(false)
  isCompleted Boolean   @default(false)
  highScore   Int       @default(0)
  topic       MathTopic @relation(fields: [topicId], references: [id], map: "UserProgress_topicId_fkey")
  user        User      @relation(fields: [userId], references: [id], map: "UserProgress_userId_fkey")

  @@index([topicId], map: "UserProgress_topicId_fkey")
  @@index([userId], map: "UserProgress_userId_fkey")
  @@map("userprogress")
}

model Analytics {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @default(now())
  solvedCount Int      @default(0)
  accuracy    Float    @default(0)
  user        User     @relation(fields: [userId], references: [id], map: "Analytics_userId_fkey")

  @@index([userId], map: "Analytics_userId_fkey")
  @@map("analytics")
}

model Theory {
  id        String   @id @default(cuid())
  category  String
  grade     String
  content   String   @db.LongText
  updatedAt DateTime @updatedAt
  topicId   String?

  @@unique([category, topicId, grade], map: "Theory_category_topicId_grade_key")
  @@map("theory")
}

model AIBankSoal {
  id        String   @id @default(cuid())
  category  String
  grade     String
  questions String   @db.LongText
  updatedAt DateTime @updatedAt
  topicId   String?

  @@unique([category, topicId, grade], map: "AIBankSoal_category_topicId_grade_key")
  @@map("aibanksoal")
}

model GameProgress {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  level     Int      @default(1)
  isMaxed   Boolean  @default(false)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], map: "GameProgress_userId_fkey")

  @@unique([userId, gameId], map: "GameProgress_userId_gameId_key")
  @@map("gameprogress")
}

model LearningProgress {
  id          String   @id @default(cuid())
  userId      String
  categoryId  String
  topicId     String
  score       Int      @default(0)
  isCompleted Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], map: "LearningProgress_userId_fkey")

  @@unique([userId, categoryId, topicId], map: "LearningProgress_userId_categoryId_topicId_key")
  @@map("learningprogress")
}
